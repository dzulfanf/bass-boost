{
  "manifest_version": 3,
  "name": "Bass Boost",
  "version": "1.3",
  "description": "Bass boost, 10-band EQ & audio enhancer for YouTube, Spotify, Netflix and any site.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "externally_connectable": {
    "matches": [
      "https://*.railway.app/*",
      "https://*.vercel.app/*",
      "http://localhost:3000/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }]
}
