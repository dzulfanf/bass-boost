{
  "manifest_version": 3,
  "name": "Bass Boost",
  "version": "1.0",
  "description": "Bass boost, 10-band EQ & audio enhancer for any website.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": ["https://bass-boost-backend.vercel.app/*"],
  "externally_connectable": {
    "matches": [
      "https://bass-boost-landing.vercel.app/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self';"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }]
}
